{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,

    "lib": ["es2022"],

    "module": "nodenext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,

    "strict": true,
    "target": "es2022",
    "verbatimModuleSyntax": true
  }
}
